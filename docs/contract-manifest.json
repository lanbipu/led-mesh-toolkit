      "summary": "Dump JsonSchema of all public DTOs + envelope + error types",
      "cli": "lmt schema",
      "side_effect": "read_only",
      "supports_dry_run": false,
      "supports_stdin": false,
      "idempotent": true,
      "open_world": false,
      "output_type": null,
      "exit_codes": [
        0
      ]
    },
    {
      "operation_id": "manifest",
      "summary": "Dump the Contract Manifest (this operation list)",
